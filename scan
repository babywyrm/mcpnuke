#!/usr/bin/env bash
# Zero-config mcpnuke runner — no venv activation needed.
# Usage: ./scan --targets http://localhost:9090
#        ./scan --port-range localhost:9001-9010 --verbose
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# Prefer uv run (respects UV_PROJECT_ENVIRONMENT, .python-version, etc.)
if command -v uv &>/dev/null; then
    exec uv run python -m mcpnuke "$@"
fi

# Fallback: direct venv Python
VENV_PYTHON="$SCRIPT_DIR/.venv/bin/python"
if [ -f "$VENV_PYTHON" ]; then
    exec "$VENV_PYTHON" -m mcpnuke "$@"
fi

echo "Error: uv not found and .venv missing — run: uv sync --all-extras" >&2
exit 1
